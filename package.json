{
  "name": "lobster-studio",
  "version": "1.0.0",
  "description": "龙虾短剧工坊 - AI 原生短剧创作平台",
  "main": "src/main/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"electron .\"",
    "build": "vite build && electron-builder",
    "vite:dev": "vite",
    "electron:dev": "electron ."
  },
  "dependencies": {
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "compute-cosine-similarity": "^1.1.0",
    "framer-motion": "^12.0.0",
    "lucide-react": "^0.400.0",
    "node-fetch": "^3.3.2",
    "openai": "^6.42.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0",
    "sql.js": "^1.14.1",
    "tailwindcss": "^4.0.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.0.0",
    "concurrently": "^9.0.0",
    "electron": "^34.5.8",
    "electron-builder": "^26.15.2",
    "postcss": "^8.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  },
  "build": {
    "appId": "com.lobster.studio",
    "productName": "龙虾短剧工坊",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "public/icon.png"
    },
    "mac": {
      "target": [
        "dmg"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    }
  }
}
